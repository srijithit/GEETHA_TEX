<%- include('partials/header') %>

  <section class="page-header">
    <div class="container">
      <h1>Checkout</h1>
      <p>Complete your purchase</p>
    </div>
  </section>

  <section class="checkout-section section">
    <div class="container">
      <div class="checkout-grid">
        <!-- Customer Details Form -->
        <div class="checkout-form-container">
          <h2><i class="fas fa-user"></i> Shipping Details</h2>
          <form id="checkout-form" class="checkout-form">
            <div class="form-group">
              <label for="cust-name">Full Name *</label>
              <input type="text" id="cust-name" name="name" required placeholder="Enter your full name">
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="cust-email">Email</label>
                <input type="email" id="cust-email" name="email" placeholder="your@email.com">
              </div>
              <div class="form-group">
                <label for="cust-phone">Phone *</label>
                <input type="tel" id="cust-phone" name="phone" required placeholder="Your phone number">
              </div>
            </div>
            <div class="form-group">
              <label for="cust-address">Address *</label>
              <textarea id="cust-address" name="address" rows="3" required placeholder="House/Flat No, Street, Area"></textarea>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="cust-city">City *</label>
                <input type="text" id="cust-city" name="city" required placeholder="City">
              </div>
              <div class="form-group">
                <label for="cust-pincode">Pincode *</label>
                <input type="text" id="cust-pincode" name="pincode" required placeholder="636001" maxlength="6">
              </div>
            </div>
          </form>
        </div>

        <!-- Order Summary -->
        <div class="order-summary-container">
          <h2><i class="fas fa-receipt"></i> Order Summary</h2>
          <div id="checkout-items">
            <!-- Items populated by JS -->
          </div>
          <div class="summary-totals">
            <div class="summary-row">
              <span>Subtotal</span>
              <span id="checkout-subtotal">₹0</span>
            </div>
            <div class="summary-row">
              <span>Shipping</span>
              <span id="checkout-shipping" class="text-success">Free</span>
            </div>
            <div class="summary-row total-row">
              <span>Total</span>
              <span id="checkout-total">₹0</span>
            </div>
          </div>
          <button class="btn btn-primary btn-lg btn-block" id="pay-btn" onclick="initiateWhatsAppOrder()">
            <i class="fab fa-whatsapp"></i> Order via WhatsApp
          </button>
          <p class="secure-note"><i class="fas fa-shield-halved"></i> Your payment is 100% secure</p>
        </div>
      </div>
    </div>
  </section>

  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
  <script>
    const RAZORPAY_KEY_ID = '<%= razorpayKeyId %>';

    // Load checkout items
    document.addEventListener('DOMContentLoaded', loadCheckoutItems);

    async function loadCheckoutItems() {
      const cart = JSON.parse(localStorage.getItem('geethaCart') || '[]');
      if (cart.length === 0) {
        window.location.href = '/cart';
        return;
      }

      const container = document.getElementById('checkout-items');
      let subtotal = 0;

      // Fetch product details
      const ids = cart.map(item => item.id);
      try {
        const res = await fetch('/api/products/batch', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ids })
        });
        const products = await res.json();

        let html = '';
        cart.forEach(item => {
          const product = products.find(p => p.id === item.id);
          if (product) {
            const itemTotal = product.price * item.qty;
            subtotal += itemTotal;
            html += `
              <div class="checkout-item">
                <div class="checkout-item-info">
                  <strong>${product.name}</strong>
                  <span>Qty: ${item.qty} × ₹${product.price.toLocaleString('en-IN')}</span>
                </div>
                <span class="checkout-item-price">₹${itemTotal.toLocaleString('en-IN')}</span>
              </div>
            `;
          }
        });

        container.innerHTML = html;
        document.getElementById('checkout-subtotal').textContent = '₹' + subtotal.toLocaleString('en-IN');
        document.getElementById('checkout-total').textContent = '₹' + subtotal.toLocaleString('en-IN');

        if (subtotal < 5000) {
          document.getElementById('checkout-shipping').textContent = '₹99';
          document.getElementById('checkout-total').textContent = '₹' + (subtotal + 99).toLocaleString('en-IN');
        }
      } catch (error) {
        container.innerHTML = '<p>Error loading items. Please go back to cart.</p>';
      }
    }

    async function initiateWhatsAppOrder() {
      const form = document.getElementById('checkout-form');
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      const cart = JSON.parse(localStorage.getItem('geethaCart') || '[]');
      const customerInfo = {
        name: document.getElementById('cust-name').value,
        phone: document.getElementById('cust-phone').value,
        address: document.getElementById('cust-address').value,
        city: document.getElementById('cust-city').value,
        pincode: document.getElementById('cust-pincode').value
      };

      const totalText = document.getElementById('checkout-total').textContent;
      
      // Get product names for the message
      const items = document.querySelectorAll('.checkout-item');
      let itemsList = '';
      items.forEach(item => {
        const name = item.querySelector('strong').innerText;
        const details = item.querySelector('span').innerText;
        itemsList += `• ${name} (${details})\n`;
      });

      const message = `*New Order from Geetha Tex Website*\n\n` +
                      `*Customer Details:*\n` +
                      `Name: ${customerInfo.name}\n` +
                      `Phone: ${customerInfo.phone}\n` +
                      `Address: ${customerInfo.address}, ${customerInfo.city} - ${customerInfo.pincode}\n\n` +
                      `*Order Items:*\n${itemsList}\n` +
                      `*Total Amount: ${totalText}*\n\n` +
                      `Please confirm my order. Thank you!`;

      const encodedMessage = encodeURIComponent(message);
      const whatsappUrl = `https://wa.me/918438860182?text=${encodedMessage}`;

      // Optional: Save order to DB as 'whatsapp_pending'
      try {
        await fetch('/create-order-whatsapp', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ customerInfo, items: cart, total: totalText })
        });
      } catch (e) { console.error("Error saving order"); }

      // Clear cart and redirect
      localStorage.removeItem('geethaCart');
      window.open(whatsappUrl, '_blank');
      window.location.href = '/order-success';
    }
  </script>

<%- include('partials/footer') %>
