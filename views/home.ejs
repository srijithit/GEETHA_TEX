<%- include('partials/header') %>

  <!-- Hero Section -->
  <section class="hero" id="hero">
    <div class="hero-bg-pattern"></div>
    <div class="hero-content">
      <div class="hero-badge">✨ Handwoven in Salem, Tamil Nadu</div>
      <h1 class="hero-title">
        <span class="hero-title-line">Timeless Elegance</span>
        <span class="hero-title-line accent">Woven in Every Thread</span>
      </h1>
      <p class="hero-subtitle">Discover our exquisite collection of handwoven Soft Silk & Kerala Sarees — crafted with generations of artistry and tradition</p>
      <div class="hero-cta">
        <a href="/products" class="btn btn-primary btn-lg" id="hero-shop-btn">
          <span>Explore Collection</span>
          <i class="fas fa-arrow-right"></i>
        </a>
        <a href="/about" class="btn btn-outline btn-lg" id="hero-about-btn">
          <span>Our Story</span>
        </a>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-number">30+</span>
          <span class="stat-label">Years Legacy</span>
        </div>
        <div class="stat">
          <span class="stat-number">10K+</span>
          <span class="stat-label">Happy Customers</span>
        </div>
        <div class="stat">
          <span class="stat-number">500+</span>
          <span class="stat-label">Unique Designs</span>
        </div>
      </div>
    </div>
    <div class="hero-scroll-indicator">
      <span>Scroll Down</span>
      <i class="fas fa-chevron-down"></i>
    </div>
  </section>

  <!-- Categories Section -->
  <section class="categories-section section" id="categories">
    <div class="container">
      <div class="section-header">
        <span class="section-badge">Collections</span>
        <h2 class="section-title">Shop by Category</h2>
        <p class="section-subtitle">Explore our carefully curated collections of finest sarees</p>
      </div>
      <div class="categories-grid">
        <a href="/products?category=Soft Silk" class="category-card" id="cat-soft-silk">
          <div class="category-icon">🧵</div>
          <h3>Soft Silk</h3>
          <p>Luxurious silk sarees with intricate zari work</p>
          <span class="category-link">Shop Now <i class="fas fa-arrow-right"></i></span>
        </a>
        <a href="/products?category=Kerala Sarees" class="category-card" id="cat-kerala">
          <div class="category-icon">🌴</div>
          <h3>Kerala Sarees</h3>
          <p>Authentic Kasavu sarees & traditional mundu</p>
          <span class="category-link">Shop Now <i class="fas fa-arrow-right"></i></span>
        </a>
        <a href="/products?category=Wedding Collection" class="category-card" id="cat-wedding">
          <div class="category-icon">💍</div>
          <h3>Wedding Collection</h3>
          <p>Grand bridal sarees for your special day</p>
          <span class="category-link">Shop Now <i class="fas fa-arrow-right"></i></span>
        </a>
        <a href="/products?category=Festive Collection" class="category-card" id="cat-festive">
          <div class="category-icon">🎊</div>
          <h3>Festive Collection</h3>
          <p>Vibrant sarees for festivals & celebrations</p>
          <span class="category-link">Shop Now <i class="fas fa-arrow-right"></i></span>
        </a>
        <a href="/products?category=New Arrivals" class="category-card" id="cat-new">
          <div class="category-icon">🌟</div>
          <h3>New Arrivals</h3>
          <p>Latest designs fresh from our looms</p>
          <span class="category-link">Shop Now <i class="fas fa-arrow-right"></i></span>
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Products -->
  <section class="featured-section section" id="featured">
    <div class="container">
      <div class="section-header">
        <span class="section-badge">Best Sellers</span>
        <h2 class="section-title">Featured Collection</h2>
        <p class="section-subtitle">Our most loved sarees, handpicked for you</p>
      </div>
      <div class="products-grid">
        <% featured.forEach(function(product) { %>
          <div class="product-card" id="product-card-<%= product.id %>">
            <a href="/products/<%= product.id %>" class="product-image-link">
              <div class="product-image">
                <img src="/uploads/<%= product.image %>" alt="<%= product.name %>" loading="lazy"
                     onerror="this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 400 500%22><rect fill=%22%23f3e8d9%22 width=%22400%22 height=%22500%22/><text x=%2250%%22 y=%2250%%22 text-anchor=%22middle%22 fill=%22%238B1A1A%22 font-size=%2248%22>🪷</text><text x=%2250%%22 y=%2265%%22 text-anchor=%22middle%22 fill=%22%23666%22 font-size=%2214%22>Geetha Tex</text></svg>'">
                <% if (product.original_price) { %>
                  <span class="product-badge">-<%= Math.round((1 - product.price/product.original_price) * 100) %>%</span>
                <% } %>
                <div class="product-overlay">
                  <button class="btn-icon" onclick="event.preventDefault(); addToCart(<%= product.id %>)" title="Add to Cart">
                    <i class="fas fa-shopping-bag"></i>
                  </button>
                  <a href="/products/<%= product.id %>" class="btn-icon" title="View Details">
                    <i class="fas fa-eye"></i>
                  </a>
                </div>
              </div>
            </a>
            <div class="product-info">
              <span class="product-category"><%= product.category %></span>
              <h3 class="product-name"><a href="/products/<%= product.id %>"><%= product.name %></a></h3>
              <div class="product-price">
                <span class="current-price">₹<%= product.price.toLocaleString('en-IN') %></span>
                <% if (product.original_price) { %>
                  <span class="original-price">₹<%= product.original_price.toLocaleString('en-IN') %></span>
                <% } %>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
      <div class="section-cta">
        <a href="/products" class="btn btn-primary" id="view-all-btn">
          View All Collections <i class="fas fa-arrow-right"></i>
        </a>
      </div>
    </div>
  </section>

  <!-- Why Geetha Tex -->
  <section class="why-section section" id="why-us">
    <div class="container">
      <div class="section-header">
        <span class="section-badge">Why Choose Us</span>
        <h2 class="section-title">The Geetha Tex Promise</h2>
      </div>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon"><i class="fas fa-hand-sparkles"></i></div>
          <h3>100% Handwoven</h3>
          <p>Every saree is handwoven by skilled artisans using traditional techniques passed down through generations</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon"><i class="fas fa-gem"></i></div>
          <h3>Pure Silk & Cotton</h3>
          <p>We use only the finest quality silk and cotton threads, ensuring authenticity and comfort</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon"><i class="fas fa-truck-fast"></i></div>
          <h3>Free Shipping</h3>
          <p>Complimentary shipping on all orders above ₹5,000 across India with careful packaging</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon"><i class="fas fa-shield-halved"></i></div>
          <h3>Secure Payments</h3>
          <p>100% secure checkout powered by Razorpay. Pay with UPI, cards, or net banking</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="testimonials-section section" id="testimonials">
    <div class="container">
      <div class="section-header">
        <span class="section-badge">Testimonials</span>
        <h2 class="section-title">What Our Customers Say</h2>
      </div>
      <div class="testimonials-grid">
        <div class="testimonial-card">
          <div class="testimonial-stars">
            <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
          </div>
          <p>"The silk saree I bought for my daughter's wedding was absolutely stunning. The zari work was impeccable and everyone at the wedding couldn't stop admiring it!"</p>
          <div class="testimonial-author">
            <div class="author-avatar">P</div>
            <div>
              <strong>Priya Ramanathan</strong>
              <span>Chennai</span>
            </div>
          </div>
        </div>
        <div class="testimonial-card">
          <div class="testimonial-stars">
            <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
          </div>
          <p>"Best Kerala kasavu sarees I've ever owned. The quality is unmatched and the golden border shines beautifully. Will definitely order more for Onam!"</p>
          <div class="testimonial-author">
            <div class="author-avatar">M</div>
            <div>
              <strong>Meera Krishnan</strong>
              <span>Kochi</span>
            </div>
          </div>
        </div>
        <div class="testimonial-card">
          <div class="testimonial-stars">
            <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
          </div>
          <p>"Geetha Tex has been our family's go-to store for 15 years. Their commitment to authentic handwoven sarees is remarkable. Truly a gem from Salem!"</p>
          <div class="testimonial-author">
            <div class="author-avatar">S</div>
            <div>
              <strong>Saranya Devi</strong>
              <span>Coimbatore</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="cta-banner" id="cta-banner">
    <div class="container">
      <div class="cta-content">
        <h2>Visit Our Store in Salem</h2>
        <p>Experience the beauty of our sarees in person. Our team will help you find the perfect saree for every occasion.</p>
        <a href="/contact" class="btn btn-primary btn-lg">
          <i class="fas fa-map-marker-alt"></i> Get Directions
        </a>
      </div>
    </div>
  </section>

<%- include('partials/footer') %>
