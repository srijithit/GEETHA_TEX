<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Geetha Tex - Premium Soft Silk & Kerala Sarees from Salem, Tamil Nadu. Handwoven traditional sarees for weddings, festivals & celebrations.">
  <meta name="keywords" content="silk sarees, kerala sarees, kasavu, kanchipuram, salem, tamil nadu, wedding sarees, handloom">
  <title>Geetha Tex — Premium Silk & Kerala Sarees</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <!-- Announcement Bar -->
  <div class="announcement-bar">
    <p><i class="fas fa-truck"></i> Free Shipping on Orders Above ₹5,000 | <i class="fas fa-tag"></i> Use Code <strong>GEETHA10</strong> for 10% Off</p>
  </div>

  <!-- Navigation -->
  <nav class="navbar" id="navbar">
    <div class="nav-container">
      <a href="/" class="logo" id="logo">
        <img src="/images/logo.png" alt="Geetha Tex Logo" class="logo-img">
      </a>

      <ul class="nav-links" id="navLinks">
        <li><a href="/" class="<%= page === 'home' ? 'active' : '' %>" id="nav-home">Home</a></li>
        <li><a href="/products" class="<%= page === 'products' ? 'active' : '' %>" id="nav-products">Collections</a></li>
        <li><a href="/about" class="<%= page === 'about' ? 'active' : '' %>" id="nav-about">About</a></li>
        <li><a href="/contact" class="<%= page === 'contact' ? 'active' : '' %>" id="nav-contact">Contact</a></li>
      </ul>

      <div class="nav-actions">
        <a href="/products" class="nav-icon" id="nav-search-btn" title="Search">
          <i class="fas fa-search"></i>
        </a>
        <a href="/cart" class="nav-icon cart-icon" id="nav-cart-btn" title="Cart">
          <i class="fas fa-shopping-bag"></i>
          <span class="cart-count" id="cartCount">0</span>
        </a>
        <button class="hamburger" id="hamburger" aria-label="Menu">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </div>
