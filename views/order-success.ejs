<%- include('partials/header') %>

  <section class="success-section">
    <div class="container">
      <div class="success-card">
        <div class="success-icon">
          <i class="fas fa-check-circle"></i>
        </div>
        <h1>Order Placed Successfully!</h1>
        <p class="success-msg">Thank you for shopping with Geetha Tex. Your order has been confirmed.</p>
        
        <% if (paymentId) { %>
          <div class="payment-info">
        <p>Need help? Contact us at <strong>+91 84388 60182</strong> or <strong>geethatex@gmail.com</strong></p>
          </div>
        <% } %>

        <div class="success-details">
          <div class="detail-item">
            <i class="fas fa-envelope"></i>
            <p>Order confirmation will be sent to your email</p>
          </div>
          <div class="detail-item">
            <i class="fas fa-truck"></i>
            <p>Your saree will be shipped within 2-3 business days</p>
          </div>
          <div class="detail-item">
            <p>For any queries, call us at +91 84388 60182</p>
          </div>
        </div>

        <div class="success-actions">
          <a href="/products" class="btn btn-primary btn-lg">
            <i class="fas fa-shopping-bag"></i> Continue Shopping
          </a>
          <a href="/" class="btn btn-outline btn-lg">
            <i class="fas fa-home"></i> Back to Home
          </a>
        </div>
      </div>
    </div>
  </section>

<%- include('partials/footer') %>
