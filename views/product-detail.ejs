<%- include('partials/header') %>

  <section class="product-detail-section section">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a> <i class="fas fa-chevron-right"></i>
        <a href="/products">Collections</a> <i class="fas fa-chevron-right"></i>
        <a href="/products?category=<%= encodeURIComponent(product.category) %>"><%= product.category %></a> <i class="fas fa-chevron-right"></i>
        <span><%= product.name %></span>
      </div>

      <div class="product-detail" id="product-detail">
        <div class="product-detail-image">
          <div class="main-image">
            <img src="/uploads/<%= product.image %>" alt="<%= product.name %>" id="main-product-image"
                 onerror="this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 600 700%22><rect fill=%22%23f3e8d9%22 width=%22600%22 height=%22700%22/><text x=%2250%%22 y=%2245%%22 text-anchor=%22middle%22 fill=%22%238B1A1A%22 font-size=%2272%22>🪷</text><text x=%2250%%22 y=%2255%%22 text-anchor=%22middle%22 fill=%22%23666%22 font-size=%2218%22>Geetha Tex</text><text x=%2250%%22 y=%2262%%22 text-anchor=%22middle%22 fill=%22%23999%22 font-size=%2214%22>Product Image</text></svg>'">
            <% if (product.original_price) { %>
              <span class="product-badge badge-lg">-<%= Math.round((1 - product.price/product.original_price) * 100) %>% OFF</span>
            <% } %>
          </div>
        </div>

        <div class="product-detail-info">
          <span class="product-category-tag"><%= product.category %></span>
          <h1 class="product-detail-name"><%= product.name %></h1>
          
          <div class="product-rating">
            <div class="stars">
              <i class="fas fa-star"></i>
              <i class="fas fa-star"></i>
              <i class="fas fa-star"></i>
              <i class="fas fa-star"></i>
              <i class="fas fa-star-half-alt"></i>
            </div>
            <span>4.5 (128 reviews)</span>
          </div>

          <div class="product-detail-price">
            <span class="detail-current-price">₹<%= product.price.toLocaleString('en-IN') %></span>
            <% if (product.original_price) { %>
              <span class="detail-original-price">₹<%= product.original_price.toLocaleString('en-IN') %></span>
              <span class="detail-savings">You save ₹<%= (product.original_price - product.price).toLocaleString('en-IN') %></span>
            <% } %>
          </div>

          <p class="product-detail-desc"><%= product.description %></p>

          <div class="product-meta">
            <div class="meta-item">
              <span class="meta-label">Availability</span>
              <span class="meta-value <%= product.stock > 0 ? 'in-stock' : 'out-of-stock' %>">
                <i class="fas fa-circle"></i> <%= product.stock > 0 ? 'In Stock' : 'Out of Stock' %>
              </span>
            </div>
            <div class="meta-item">
              <span class="meta-label">Category</span>
              <span class="meta-value"><%= product.category %></span>
            </div>
            <div class="meta-item">
              <span class="meta-label">SKU</span>
              <span class="meta-value">GT-<%= product.id.toString().padStart(4, '0') %></span>
            </div>
          </div>

          <div class="product-actions">
            <div class="quantity-selector">
              <button class="qty-btn" onclick="changeQty(-1)" id="qty-minus">−</button>
              <input type="number" value="1" min="1" max="10" id="product-qty" class="qty-input">
              <button class="qty-btn" onclick="changeQty(1)" id="qty-plus">+</button>
            </div>
            <button class="btn btn-primary btn-lg btn-add-cart-detail" onclick="addToCartWithQty(<%= product.id %>)" id="add-to-cart-btn">
              <i class="fas fa-shopping-bag"></i> Add to Cart
            </button>
            <button class="btn btn-accent btn-lg" onclick="buyNow(<%= product.id %>)" id="buy-now-btn">
              <i class="fas fa-bolt"></i> Buy Now
            </button>
          </div>

          <div class="product-assurance">
            <div class="assurance-item">
              <i class="fas fa-truck"></i>
              <span>Free Delivery</span>
            </div>
            <div class="assurance-item">
              <i class="fas fa-undo"></i>
              <span>Easy Returns</span>
            </div>
            <div class="assurance-item">
              <i class="fas fa-shield-halved"></i>
              <span>Secure Payment</span>
            </div>
            <div class="assurance-item">
              <i class="fas fa-certificate"></i>
              <span>Authentic Product</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Related Products -->
      <% if (related.length > 0) { %>
        <div class="related-section">
          <h2 class="section-title">You May Also Like</h2>
          <div class="products-grid">
            <% related.forEach(function(rp) { %>
              <div class="product-card" id="related-<%= rp.id %>">
                <a href="/products/<%= rp.id %>" class="product-image-link">
                  <div class="product-image">
                    <img src="/uploads/<%= rp.image %>" alt="<%= rp.name %>" loading="lazy"
                         onerror="this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 400 500%22><rect fill=%22%23f3e8d9%22 width=%22400%22 height=%22500%22/><text x=%2250%%22 y=%2250%%22 text-anchor=%22middle%22 fill=%22%238B1A1A%22 font-size=%2248%22>🪷</text></svg>'">
                  </div>
                </a>
                <div class="product-info">
                  <span class="product-category"><%= rp.category %></span>
                  <h3 class="product-name"><a href="/products/<%= rp.id %>"><%= rp.name %></a></h3>
                  <div class="product-price">
                    <span class="current-price">₹<%= rp.price.toLocaleString('en-IN') %></span>
                  </div>
                </div>
              </div>
            <% }); %>
          </div>
        </div>
      <% } %>
    </div>
  </section>

  <script>
    function changeQty(delta) {
      const input = document.getElementById('product-qty');
      let val = parseInt(input.value) + delta;
      if (val < 1) val = 1;
      if (val > 10) val = 10;
      input.value = val;
    }

    function addToCartWithQty(productId) {
      const qty = parseInt(document.getElementById('product-qty').value);
      for (let i = 0; i < qty; i++) {
        addToCart(productId);
      }
    }

    function buyNow(productId) {
      const qty = parseInt(document.getElementById('product-qty').value);
      // Clear cart and add just this item
      localStorage.setItem('geethaCart', JSON.stringify([{ id: productId, qty }]));
      updateCartCount();
      window.location.href = '/checkout';
    }
  </script>

<%- include('partials/footer') %>
