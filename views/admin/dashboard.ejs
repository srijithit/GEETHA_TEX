<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard — Geetha Tex</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="admin-body">
  <!-- Admin Sidebar -->
  <div class="admin-layout">
    <%- include('partials/sidebar', { page: 'admin-dashboard' }) %>

    <!-- Main Content -->
    <main class="admin-main">
      <div class="admin-topbar">
        <button class="sidebar-toggle" onclick="toggleSidebar()" id="sidebar-toggle-btn">
          <i class="fas fa-bars"></i>
        </button>
        <h1>Dashboard</h1>
        <div class="admin-user">
          <i class="fas fa-user-shield"></i> Admin
        </div>
      </div>

      <!-- Stats Cards -->
      <div class="stats-grid">
        <div class="stat-card stat-products">
          <div class="stat-card-icon"><i class="fas fa-box"></i></div>
          <div class="stat-card-info">
            <h3><%= stats.totalProducts %></h3>
            <p>Total Products</p>
          </div>
        </div>
        <div class="stat-card stat-orders">
          <div class="stat-card-icon"><i class="fas fa-shopping-cart"></i></div>
          <div class="stat-card-info">
            <h3><%= stats.totalOrders %></h3>
            <p>Total Orders</p>
          </div>
        </div>
        <div class="stat-card stat-revenue">
          <div class="stat-card-icon"><i class="fas fa-indian-rupee-sign"></i></div>
          <div class="stat-card-info">
            <h3>₹<%= stats.totalRevenue.toLocaleString('en-IN') %></h3>
            <p>Total Revenue</p>
          </div>
        </div>
        <div class="stat-card stat-pending">
          <div class="stat-card-icon"><i class="fas fa-clock"></i></div>
          <div class="stat-card-info">
            <h3><%= stats.pendingOrders %></h3>
            <p>Pending Orders</p>
          </div>
        </div>
      </div>

      <!-- Products Table -->
      <div class="admin-section">
        <div class="section-header-row">
          <h2><i class="fas fa-box"></i> Products</h2>
          <a href="/admin/add-product" class="btn btn-primary" id="add-product-btn">
            <i class="fas fa-plus"></i> Add Product
          </a>
        </div>
        <div class="table-responsive">
          <table class="admin-table" id="products-table">
            <thead>
              <tr>
                <th>Image</th>
                <th>Name</th>
                <th>Category</th>
                <th>Price</th>
                <th>Stock</th>
                <th>Featured</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% products.forEach(function(product) { %>
                <tr id="product-row-<%= product.id %>">
                  <td>
                    <img src="/uploads/<%= product.image %>" alt="<%= product.name %>" class="table-img"
                         onerror="this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 60 60%22><rect fill=%22%23f3e8d9%22 width=%2260%22 height=%2260%22/><text x=%2250%%22 y=%2255%%22 text-anchor=%22middle%22 fill=%22%238B1A1A%22 font-size=%2220%22>🪷</text></svg>'">
                  </td>
                  <td><strong><%= product.name %></strong></td>
                  <td><span class="category-badge"><%= product.category %></span></td>
                  <td>₹<%= product.price.toLocaleString('en-IN') %></td>
                  <td><%= product.stock %></td>
                  <td>
                    <span class="badge <%= product.featured ? 'badge-success' : 'badge-muted' %>">
                      <%= product.featured ? 'Yes' : 'No' %>
                    </span>
                  </td>
                  <td class="actions-cell">
                    <a href="/admin/edit-product/<%= product.id %>" class="btn-action btn-edit" title="Edit">
                      <i class="fas fa-edit"></i>
                    </a>
                    <form action="/admin/delete-product/<%= product.id %>" method="POST" style="display:inline;" 
                          onsubmit="return confirm('Are you sure you want to delete this product?')">
                      <button type="submit" class="btn-action btn-delete" title="Delete">
                        <i class="fas fa-trash"></i>
                      </button>
                    </form>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Orders Table -->
      <div class="admin-section">
        <div class="section-header-row">
          <h2><i class="fas fa-shopping-cart"></i> Recent Orders</h2>
        </div>
        <% if (orders.length > 0) { %>
          <div class="table-responsive">
            <table class="admin-table" id="orders-table">
              <thead>
                <tr>
                  <th>Order ID</th>
                  <th>Customer</th>
                  <th>Phone</th>
                  <th>Total</th>
                  <th>Status</th>
                  <th>Date</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <% orders.forEach(function(order) { %>
                  <tr id="order-row-<%= order.id %>">
                    <td>#GT<%= order.id.toString().padStart(4, '0') %></td>
                    <td><strong><%= order.customer_name %></strong></td>
                    <td><%= order.phone %></td>
                    <td>₹<%= order.total.toLocaleString('en-IN') %></td>
                    <td>
                      <span class="badge badge-<%= order.status === 'paid' ? 'success' : order.status === 'shipped' ? 'info' : order.status === 'delivered' ? 'primary' : 'warning' %>">
                        <%= order.status %>
                      </span>
                    </td>
                    <td><%= new Date(order.created_at).toLocaleDateString('en-IN') %></td>
                    <td>
                      <form action="/admin/update-order/<%= order.id %>" method="POST" class="inline-form">
                        <select name="status" class="status-select" onchange="this.form.submit()">
                          <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>Pending</option>
                          <option value="paid" <%= order.status === 'paid' ? 'selected' : '' %>>Paid</option>
                          <option value="shipped" <%= order.status === 'shipped' ? 'selected' : '' %>>Shipped</option>
                          <option value="delivered" <%= order.status === 'delivered' ? 'selected' : '' %>>Delivered</option>
                          <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                        </select>
                      </form>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <div class="empty-state-admin">
            <i class="fas fa-shopping-cart"></i>
            <p>No orders yet</p>
          </div>
        <% } %>
      </div>
    </main>
  </div>

  <script>
    function toggleSidebar() {
      document.querySelector('.admin-layout').classList.toggle('sidebar-collapsed');
    }
  </script>
</body>
</html>
